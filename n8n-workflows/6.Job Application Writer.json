    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Access the 'output' string from the current item\nconst rawString = $input.item.json.output;\n\nif (!rawString) {\n  return { json: { error: \"No output field found\" } };\n}\n\ntry {\n  // 1. Remove potential Markdown code blocks\n  const cleanString = rawString.replace(/```json|```/g, \"\").trim();\n  \n  // 2. Parse the string into a real object\n  const parsed = JSON.parse(cleanString);\n\n  // 3. Return the parsed data\n  return {\n    json: parsed\n  };\n} catch (error) {\n  return {\n    json: {\n      error: \"Invalid JSON format\",\n      original_output: rawString\n    }\n  };\n}"
      },
