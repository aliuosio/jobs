      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst result = {\n  id: $('Loop').first().json.id,\n  title: $('Loop').first().json.title,\n  description: ''\n};\n\n// Handle crawl4ai LLM extraction response\nif (input && input.results && input.results[0] && input.results[0].extracted_content) {\n  result.description = input.results[0].extracted_content;\n} else if (input && input.results && input.results[0] && input.results[0].markdown && input.results[0].markdown.raw_markdown) {\n  result.description = input.results[0].markdown.raw_markdown;\n} else if (input && input.data && input.data[0] && input.data[0].content) {\n  result.description = input.data[0].content;\n} else if (input && input.message) {\n  result.description = input.message;\n} else {\n  result.description = 'No content available';\n}\n\nreturn [result];"
      },
