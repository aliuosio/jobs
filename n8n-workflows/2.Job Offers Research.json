        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"urls\": [\n    \"{{$json.url}}\"\n  ],\n  \"browser_config\": {\n    \"type\": \"BrowserConfig\",\n    \"params\": {\n      \"headless\": true,\n      \"enable_stealth\": true,\n      \"headers\": {\n        \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/122.0.0.0 Safari/537.36\",\n        \"Accept-Language\": \"de-DE,de;q=0.9,en-US;q=0.8,en;q=0.7\",\n        \"Referer\": \"https://www.google.com/\"\n      },\n      \"cookies\": [\n        {\n          \"name\": \"{{$json.cookie_name}}\",\n          \"value\": \"{{$json.cookie}}\",\n          \"domain\": \"{{$json.domain}}\",\n          \"path\": \"/\",\n          \"secure\": true\n        }\n      ]\n    }\n  },\n  \"crawler_config\": {\n    \"type\": \"CrawlerRunConfig\",\n    \"params\": {\n      \"magic\": true,\n      \"cache_mode\": \"bypass\",\n      \"wait_until\": \"networkidle\",\n      \"page_timeout\": 60000,\n      \"remove_overlay_elements\": true,\n      \"verbose\": true,\n      \"js_code\": \"await new Promise(r => setTimeout(r, 3000)); await window.scrollTo(0, document.body.scrollHeight / 3); await new Promise(r => setTimeout(r, 1500)); await window.scrollTo(0, document.body.scrollHeight * 0.66); await new Promise(r => setTimeout(r, 1500)); await window.scrollTo(0, document.body.scrollHeight);\"\n    }\n  }\n}",
