      "parameters": {
        "jsCode": "// 1. Grab inputs\nconst createdAtRaw = $('Get Last Created').first().json.created_at; \nconst defaultDate = \"2026-01-01\";\n\n// 2. Setup \"Today\" at midnight for comparison\nconst today = new Date();\ntoday.setHours(0, 0, 0, 0);\n\nlet since;\n\nconst createdAtDate = new Date(createdAtRaw);\n\n// Create a copy of createdAtDate set to midnight to compare only the calendar date\nconst createdAtMidnight = new Date(createdAtDate);\ncreatedAtMidnight.setHours(0, 0, 0, 0);\n\nif (createdAtMidnight <= today) {\n    // Scenario: Date is strictly in the past (yesterday or older)\n    since = createdAtDate.toISOString().split('T')[0];\n} else {\n    // Scenario: Date is Today or in the future\n    since = defaultDate;\n}\n\n// Return the appropriate values\nreturn { since };\n"
      },
