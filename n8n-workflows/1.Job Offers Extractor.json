    },
    {
      "parameters": {
        "jsCode": "// Input: email text in item.json.text\nreturn items.map(item => {\n    const text = $input.first().json.textContent || '';\n\n    // Regex to capture LinkedIn job URLs with view ID\n    const regex = /https?:\\/\\/www\\.linkedin\\.com\\/comm\\/jobs\\/view\\/(\\d+)([^\\s]*)/g;\n\n    // Replace each match with a clean URL\n    const cleanedText = text.replace(regex, (match, viewId) => {\n        return `https://www.linkedin.com/comm/jobs/view/${viewId}/`;\n    });\n\n    return {\n        json: {\n            cleanedText\n        }\n    };\n});"
      },
