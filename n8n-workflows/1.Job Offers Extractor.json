      "parameters": {
        "jsCode": "const needle = \"Alle Jobs anzeigen\";\n\n// Assume the input comes from the first item\nconst input = $input.first().json.cleanedText; // replace 'fullString' with your field name\n\n// Trim string if needle exists\nconst outputString = input.includes(needle) ? input.split(needle)[0] : input;\n\n// Return as array of objects (n8n-compatible)\nreturn [{ json: { trimmedString: outputString } }];"
      },
