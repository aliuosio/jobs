    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// ── Field is \"textContent\" ────────────────────────────────────────────────────\nconst inputText = item.textContent;\nif (!inputText) throw new Error('textContent field is empty or missing');\n\n// ── Extract clean job URL from job ID only ────────────────────────────────────\nfunction cleanLinkedInUrl(rawUrl) {\n  const m = rawUrl.match(/linkedin\\.com(?:\\/comm)?\\/jobs\\/view\\/(\\d+)/);\n  return m ? `https://www.linkedin.com/jobs/view/${m[1]}/` : null;\n}\n\n// ── Timestamp ─────────────────────────────────────────────────────────────────\nconst now = new Date();\nconst posted = [\n  now.getFullYear(),\n  String(now.getMonth() + 1).padStart(2, '0'),\n  String(now.getDate()).padStart(2, '0'),\n].join('-') + ' ' + [\n  String(now.getHours()).padStart(2, '0'),\n  String(now.getMinutes()).padStart(2, '0'),\n  String(now.getSeconds()).padStart(2, '0'),\n].join(':');\n\n// ── Split into blocks by separator lines ─────────────────────────────────────\nconst blocks = inputText.split(/-{5,}/);\n\nconst jobs = [];\n\nfor (const block of blocks) {\n  const urlMatch = block.match(/Jobangebot ansehen:\\s*(https:\\/\\/www\\.linkedin\\.com\\/[^\\s\\n]+)/);\n  if (!urlMatch) continue;\n\n  const url = cleanLinkedInUrl(urlMatch[1]);\n  if (!url) continue;\n\n  const lines = block\n    .split('\\n')\n    .map(l => l.trim())\n    .filter(l =>\n      l.length > 0 &&\n      !l.startsWith('Jobangebot ansehen') &&\n      !l.startsWith('Dieses Unternehmen') &&\n      !l.startsWith('http')\n    );\n\n  const title    = lines[0] || null;\n  const company  = lines[1] || null;\n  const location = lines[2] || null;\n\n  jobs.push({\n    json: {\n      company,\n      title,\n      email:         null,\n      url,\n      description:   null,\n      location,\n      salary:        null,\n      schedule_type: null,\n      posted,\n      via:           'linkedin',\n    }\n  });\n}\n\nif (jobs.length === 0) {\n  throw new Error('No jobs parsed from textContent. Check input format.');\n}\n\nreturn jobs;"
      },
      "type": "n8n-nodes-base.code",
