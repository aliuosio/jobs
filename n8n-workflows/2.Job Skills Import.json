      "id": "1f4258f3-9893-4db3-b7d0-e72289f122cf",
      "name": "Create Collection Resume",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        688,
        864
      ]
    },
    {
      "parameters": {
        "jsCode": "// 1. Extract the raw string from the AI Agent safely\n// Handle different possible AI output structures\nconst inputItem = $input.first();\nlet rawInput;\n\n// Try different possible paths for AI output\nif (inputItem.json && inputItem.json.data && inputItem.json.data[1] && inputItem.json.data[1].text) {\n  rawInput = inputItem.json.data[1].text;\n} else if (inputItem.json && inputItem.json.text) {\n  rawInput = inputItem.json.text;\n} else if (inputItem.json && inputItem.json.message && inputItem.json.message.content) {\n  rawInput = inputItem.json.message.content;\n} else {\n  // Fallback: try to find text in any nested structure\n  const jsonString = JSON.stringify(inputItem.json);\n  const textMatch = jsonString.match(/\"text\":\"([^\"]+)\"/);\n  if (textMatch) {\n    rawInput = textMatch[1];\n  } else {\n    rawInput = jsonString;\n  }\n}\n\nif (!rawInput) {\n  throw new Error(\"No data received from AI Agent. Check if the AI output is empty.\");\n}\n\n// 2. Clean and Parse the JSON\n// Removes markdown code blocks if the AI included them\nconst cleanData = rawInput.replace(/```json|```/g, \"\").trim();\nlet records;\n\ntry {\n  records = JSON.parse(cleanData);\n} catch (e) {\n  // Handle truncated JSON by trying to fix common issues\n  let fixedData = cleanData;\n  \n  // Try to fix truncated JSON by adding missing closing brackets\n  const openBrackets = (fixedData.match(/\\{/g) || []).length;\n  const closeBrackets = (fixedData.match(/\\}/g) || []).length;\n  const openArrays = (fixedData.match(/\\[/g) || []).length;\n  const closeArrays = (fixedData.match(/\\]/g) || []).length;\n  \n  // Add missing closing brackets/arrays\n  for (let i = 0; i < openBrackets - closeBrackets; i++) {\n    fixedData += \"}\";\n  }\n  for (let i = 0; i < openArrays - closeArrays; i++) {\n    fixedData += \"]\";\n  }\n  \n  try {\n    records = JSON.parse(fixedData);\n  } catch (e2) {\n    // If still failing, try to extract valid JSON objects from the string\n    const jsonObjects = [];\n    const objectRegex = /\\{[^{}]*(?:\\{[^{}]*\\}[^{}]*)*\\}/g;\n    let match;\n    \n    while ((match = objectRegex.exec(fixedData)) !== null) {\n      try {\n        const obj = JSON.parse(match[0]);\n        jsonObjects.push(obj);\n      } catch (e3) {\n        // Skip invalid objects\n      }\n    }\n    \n    if (jsonObjects.length > 0) {\n      records = jsonObjects;\n    } else {\n      throw new Error(\"Failed to parse AI output as JSON even after fixing. Raw text: \" + cleanData.substring(0, 200));\n    }\n  }\n}\n\n// 3. Map into n8n Item Format\nreturn records.map(item => {\n  // Create a descriptive string for the Embedding node to vectorize\n  const renderText = `Role: ${item.role || 'N/A'}. Domain: ${item.domain || 'N/A'}. Tech: ${(item.tech && item.tech.length > 0) ? item.tech.join(', ') : 'None'}.`;\n\n  return {\n    json: {\n      // TOP-LEVEL 'text' field is critical for the Gemini Embedding node\n      text: renderText,\n      \n      // All metadata fields for Qdrant filtering\n      metadata: {\n        type: item.type || \"experience\",\n        domain: item.domain || \"N/A\",\n        role: item.role || \"N/A\",\n        is_lead: !!item.is_lead_role, // Force boolean\n        company: item.company || null,\n        tech: item.tech || [],\n        start_year: item.start_year || null,\n        end_year: item.end_year || null,\n        language: item.language || \"English\"\n      }\n    }\n  };\n});"
      },
