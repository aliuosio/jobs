      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n\tjo.id, jo.company, jo.company_url, jo.title, jo.expired\nFROM \n\tjob_offers jo\nWHERE \n\tid \nIN(\n\tSELECT \n\t\tjop.job_offers_id \n\tfrom\n\t\tjob_offers_process jop \n\twhere\n\t\tjop.research_email = false\n)\n;",
