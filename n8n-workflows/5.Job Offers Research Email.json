    {
      "parameters": {
        "jsCode": "const text = $input.first().json.body;\n\nif (!text || typeof text !== 'string') {\n  return {\n    json: {\n      error: true\n    }\n  };\n}\n\nconst cleaned = text\n  // Remove script tags\n  .replace(/<script[\\s\\S]*?<\\/script>/gi, '')\n  // Remove style tags\n  .replace(/<style[\\s\\S]*?<\\/style>/gi, '')\n  // Remove link tags\n  .replace(/<link[\\s\\S]*?>/gi, '')\n  // Remove meta tags\n  .replace(/<meta[\\s\\S]*?>/gi, '')\n  // Remove inline styles\n  .replace(/\\sstyle=\"[^\"]*\"/gi, '')\n  // Remove inline JS handlers\n  .replace(/\\son\\w+=\"[^\"]*\"/gi, '');\n\nreturn {\n  json: {\n    body: cleaned\n  }\n};"
      },
