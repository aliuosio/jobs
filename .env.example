# ============================================
# Docker Infrastructure Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# General Docker Configuration
# ============================================

# Namespace prefix for container names
NAMESPACE=jobs

# User/Group IDs for file permissions (run: id -u && id -g)
UID=1000
GID=1000

# Main working directory inside n8n container
MAIN_WORKDIR=/home/node/.n8n

# ============================================
# PostgreSQL Configuration
# ============================================

POSTGRES_VERSION=16
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=n8n

# ============================================
# Redis Configuration
# ============================================

REDIS_VERSION=7-alpine

# ============================================
# n8n Configuration
# ============================================

# n8n encryption key (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# SearXNG Configuration
# ============================================

SEARXNG_VERSION=latest
SEARXNG_SECRET=your_searxng_secret_here

# ============================================
# Nginx Configuration
# ============================================

NGINX_VERSION=alpine

# ============================================
# FTP Configuration
# ============================================

FTP_USER=your_ftp_user
FTP_PASS=your_ftp_password

# ============================================
# Qdrant Vector Database Configuration
# ============================================

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=resumes
QDRANT__LOG_LEVEL=INFO

# ============================================
# Z.ai API Configuration (REQUIRED)
# ============================================

# Get your key from: https://z.ai/dashboard/api-keys
ZAI_API_KEY=your_api_key_here
ZAI_BASE_URL=https://api.z.ai/v1

# ============================================
# RAG Backend Configuration
# ============================================

# Embedding vector dimension (must match your embedding model)
EMBEDDING_DIMENSION=1536

# Number of documents to retrieve in RAG queries
RETRIEVAL_K=5

# Retry configuration for API calls
MAX_RETRIES=4
RETRY_BASE_DELAY=1.0

# ============================================
# Crawl4AI Configuration
# ============================================

# Optional: OpenAI API key for crawl4ai LLM features
# OPENAI_API_KEY=your_openai_api_key

PROMPTS_FOLDER_JOBS=./.prompts

# ============================================
# Additional Configuration from .env
# ============================================

# Qdrant Configuration
QDRANT_URL=http://qdrant:6333

# Container & Environment
NAMESPACE=jobs
UID=1000
GID=1000

# PostgreSQL Database
POSTGRES_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=n8n

DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=${POSTGRES_HOST}
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}
DB_POSTGRESDB_DB=${POSTGRES_DB}

# Core filesystem & data paths (CRITICAL)
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# Security
N8N_ENCRYPTION_KEY=your_encryption_key_here
N8N_USER_MANAGEMENT_JWT_SECRET=your_jwt_secret_here

# Networking & runtime
N8N_PORT=5678
N8N_TRUST_PROXY=true
N8N_RUNNERS_MODE=external
N8N_RUNNERS_BROKER_LISTEN_ADDRESS=0.0.0.0
N8N_RUNNERS_AUTH_TOKEN=your_runner_auth_token
N8N_RUNNERS_TASK_BROKER_URI=http://n8n:5679
N8N_RUNNERS_MAX_OLD_SPACE_SIZE=4096

# Features & flags
N8N_FEATURE_FLAGS=aiAgent
N8N_FEATURE_FLAG_CANVAS_V2=false
N8N_TEMPLATES_ENABLED=true
N8N_ALLOW_LOAD_CUSTOM_NODES=true

# UX / UI
N8N_PERSONALIZATION_ENABLED=false
N8N_DISABLE_PRODUCTION_MAIN_MENU=true

# Diagnostics & logging
N8N_DIAGNOSTICS_ENABLED=false
N8N_LOG_LEVEL=warn
N8N_NODES_DEBUG_ENABLED=false

# Git node safety
N8N_GIT_NODE_DISABLE_BARE_REPOS=true

# Permissions (IMPORTANT)
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_REST_API_ENABLED=true

N8N_CUSTOM_EXTENSIONS=/home/node/.n8n
N8N_ENABLE_COMMUNITY_NODES=true
NODE_FUNCTION_ALLOW_EXTERNAL=axios
NODE_FUNCTION_ALLOW_EXTERNAL=puppeteer-core

# Webhook & Editor URLs
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678

# Redis Configuration for n8n (Queue Mode)
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_DB=0

# Execution Data Configuration
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_PROGRESS=true
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=false
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168
EXECUTIONS_DATA_PRUNE_MAX_COUNT=50000

# External Services
MS_APP_PASSWORD=<MS_APP_PASSWORD>
OLLAMA_HOST=ollama:11434

# Evolution API Configuration
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:5432/${POSTGRES_DB}?schema=public
AUTHENTICATION_API_KEY=<AUTHENTICATION_API_KEY>
EVOLUTION_API_KEY=<EVOLUTION_API_KEY>
EVOLUTION_TOKEN=<EVOLUTION_TOKEN>
CONFIG_SESSION_PHONE_VERSION=2.3000.1023204200
WEBSOCKET_GLOBAL_EVENTS=true

# Redis Configuration for Evolution API v2
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# CoinGecko Configuration
COINGECKO_CACHE_DURATION=3600
COINGECKO_RATE_LIMIT_DELAY=1.5
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_PRO_BASE_URL=https://pro-api.coingecko.com/api/v3

# Version Variables
N8N_VERSION=stable
POSTGRES_VERSION=18.1-alpine3.22
SEARXNG_VERSION=2026.1.16-2d9f213ca
NGINX_VERSION=1.29.3-alpine3.22
REDIS_VERSION=8.4.0-alpine3.22
CRAWL4AI_VERSION=latest

# Timezone
TZ=Europe/Berlin

# LibreTranslate Configuration
LT_DEBUG=false
LT_UPDATE_MODELS=true
LT_SSL=false
LT_SUGGESTIONS=false
LT_METRICS=false
LT_HOST=0.0.0.0
LT_THREADS=12
LT_FRONTEND_TIMEOUT=2000

# Open Notebook Language Configuration
DEFAULT_LANGUAGE=de
LANGUAGE=de_DE
LANG=de_DE.UTF-8
LC_ALL=de_DE.UTF-8
OPENAI_MODEL=gpt-4o-mini

# SearXNG Configuration
SEARXNG_SECRET=your_searxng_secret_here
SEARXNG_VALKEY_URL=redis://redis:6379/2
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_BIND_ADDRESS=0.0.0.0:8080
SEARXNG_LIMITER=false
SEARXNG_IMAGE_PROXY=true
SEARXNG_LOG_LEVEL=INFO
SEARXNG_CHECK_NETWORK=false
SEARXNG_DISABLE_NETWORK_CHECKS=true

# Crawl4AI LLM Configuration
LLM_PROVIDER=mistral/mistral-large
LLM_TEMPERATURE=0.7
MISTRAL_TEMPERATURE=0.3

# Debugging Configuration
CONCURRENT=1
TIMEOUT=30000
ENABLE_DEBUGGER=true
DEBUGGER_PASSWORD=<DEBUGGER_PASSWORD>

# VNC Configuration
ENABLE_VNC=true
SE_VNC_NO_PASSWORD=true
HEADLESS=0

# Puppeteer Remote Browser Configuration
PUPPETEER_BROWSER_WS_ENDPOINT=ws://chrome:9222
PUPPETEER_PROTOCOL=cdp

# NocoDB Configuration
NC_DB=pg://postgres:5432?u=$POSTGRES_USER&p=$POSTGRES_PASSWORD&d=n8n

# Platform & System
PLATFORMS=linux/amd64,linux/arm64
MAIN_WORKDIR=/home/node/.n8n

# Ollama Configuration
OLLAMA_DEGUG=0
OLLAMA_CONNECT_LENTH=4096
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KEEP_ALIVE=24h

# Crawl4AI API Token
CRAWL4AI_API_TOKEN=your_crawl4ai_token_here
