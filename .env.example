# Qdrant Configuration
QDRANT_URL=http://qdrant-db:6333

# Z.ai API Configuration
# REQUIRED: Set your Z.ai API key
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/




NAMESPACE=jobs

# ─────────────────────────────────────────────
# Container & Environment
# ─────────────────────────────────────────────
UID=1000
GID=1000

# ─────────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=zuiCh6ohw4oofee9zei+woo
POSTGRES_DB=n8n

DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=${POSTGRES_HOST}
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}
DB_POSTGRESDB_DB=${POSTGRES_DB}

# ─────────────────────────────────────────────
# MongoDB Configuration
# ─────────────────────────────────────────────
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=mongodb
MONGODB_USER=mongodb
MONGODB_PASSWORD=zuiCh6ohw4oofee9zei+woo

MONGO_INITDB_ROOT_USERNAME=${MONGODB_USER}
MONGO_INITDB_ROOT_PASSWORD=${MONGODB_PASSWORD}
MONGO_INITDB_DATABASE=${MONGODB_DATABASE}

# ─────────────────────────────────────────────
# Core filesystem & data paths (CRITICAL)
# ─────────────────────────────────────────────
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# ─────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────
N8N_ENCRYPTION_KEY=zuiCh6ohw4oofee9zei+woo
N8N_USER_MANAGEMENT_JWT_SECRET=zuiCh6ohw4oofee9zei+woo

# ─────────────────────────────────────────────
# Networking & runtime
# ─────────────────────────────────────────────
N8N_PORT=5678
N8N_TRUST_PROXY=true
# N8N_RUNNERS_ENABLED=true
N8N_RUNNERS_MODE=external
N8N_RUNNERS_BROKER_LISTEN_ADDRESS=0.0.0.0
N8N_RUNNERS_AUTH_TOKEN=zuiCh6ohw4oofee9zei+woo
N8N_RUNNERS_TASK_BROKER_URI=http://n8n:5679
N8N_RUNNERS_MAX_OLD_SPACE_SIZE=4096

# ─────────────────────────────────────────────
# Features & flags
# ─────────────────────────────────────────────
N8N_FEATURE_FLAGS=aiAgent
N8N_FEATURE_FLAG_CANVAS_V2=false
N8N_TEMPLATES_ENABLED=true
N8N_ALLOW_LOAD_CUSTOM_NODES=true

# ─────────────────────────────────────────────
# UX / UI
# ─────────────────────────────────────────────
N8N_PERSONALIZATION_ENABLED=false
N8N_DISABLE_PRODUCTION_MAIN_MENU=true

# ─────────────────────────────────────────────
# Diagnostics & logging
# ─────────────────────────────────────────────
N8N_DIAGNOSTICS_ENABLED=false
N8N_LOG_LEVEL=warn
N8N_NODES_DEBUG_ENABLED=false

# ─────────────────────────────────────────────
# Git node safety
# ─────────────────────────────────────────────
N8N_GIT_NODE_DISABLE_BARE_REPOS=true

# ─────────────────────────────────────────────
# Permissions (IMPORTANT)
# ─────────────────────────────────────────────
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJlYjExNjFjMC1lYzlkLTQwODctYTc3Yy05NzZhY2U2ZTY1NzEiLCJpc3MiOiJuOG4iLCJhdWQiOiJwdWJsaWMtYXBpIiwianRpIjoiZDlkNWEwNTgtMzdlMS00YTdmLWI5YzItNDA5NWQ2YzQyNzU4IiwiaWF0IjoxNzcyODY0OTE2fQ.5K5yHr4nImxfCb1NLPvR2Gf0US_XEE-iGkaMGZTMP6A
N8N_REST_API_ENABLED=true

