# ============================================
# Docker Infrastructure Environment Variables
# Copy to .env and update values as needed
# ============================================

# Qdrant Configuration
# URL for connecting to Qdrant vector database
QDRANT_URL=http://qdrant-db:6333

# Z.ai API Configuration
# REQUIRED: Your Z.ai API key for embeddings
# Get your key from: https://z.ai/dashboard/api-keys
ZAI_API_KEY=your_api_key_here

# Base URL for Z.ai API endpoints
# Change this if using a custom endpoint
ZAI_BASE_URL=https://api.z.ai/v1

# Qdrant Logging Level (optional)
# Allowed values: DEBUG, INFO, WARN, ERROR
# QDRANT__LOG_LEVEL=INFO
