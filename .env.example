NODE_FUNCTION_ALLOW_EXTERNAL=puppeteer-core

# ─────────────────────────────────────────────
# Webhook & Editor URLs
# ─────────────────────────────────────────────
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678

# ─────────────────────────────────────────────
# Redis Configuration for n8n (Queue Mode)
# ─────────────────────────────────────────────
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_DB=0

# ─────────────────────────────────────────────
# Execution Data Configuration
# ─────────────────────────────────────────────
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_PROGRESS=true
EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=false
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168
EXECUTIONS_DATA_PRUNE_MAX_COUNT=50000

# ─────────────────────────────────────────────
# External Services
# ─────────────────────────────────────────────
MS_APP_PASSWORD=<MS_APP_PASSWORD>
OLLAMA_HOST=ollama:11434

# ─────────────────────────────────────────────
# Evolution API Configuration
# ─────────────────────────────────────────────
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:5432/${POSTGRES_DB}?schema=public
AUTHENTICATION_API_KEY=<AUTHENTICATION_API_KEY>
EVOLUTION_API_KEY=<EVOLUTION_API_KEY>
EVOLUTION_TOKEN=<EVOLUTION_TOKEN>
CONFIG_SESSION_PHONE_VERSION=2.3000.1023204200
WEBSOCKET_GLOBAL_EVENTS=true

# ─────────────────────────────────────────────
# Redis Configuration for Evolution API v2
# ─────────────────────────────────────────────
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# ─────────────────────────────────────────────
# Qdrant Configuration
# ─────────────────────────────────────────────
QDRANT_API_URL=<QDRANT_API_URL>
QDRANT_API_KEY=<QDRANT_API_KEY>

# ─────────────────────────────────────────────
# CoinGecko Configuration
# ─────────────────────────────────────────────
COINGECKO_CACHE_DURATION=3600
COINGECKO_RATE_LIMIT_DELAY=1.5
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_PRO_BASE_URL=https://pro-api.coingecko.com/api/v3

# ─────────────────────────────────────────────
# Version Variables
# ─────────────────────────────────────────────
N8N_VERSION=stable
POSTGRES_VERSION=18.1-alpine3.22
SEARXNG_VERSION=2026.1.16-2d9f213ca
NGINX_VERSION=1.29.3-alpine3.22
REDIS_VERSION=8.4.0-alpine3.22
CRAWL4AI_VERSION=latest


# ─────────────────────────────────────────────
# Timezone
# ─────────────────────────────────────────────
TZ=Europe/Berlin

# ─────────────────────────────────────────────
# LibreTranslate Configuration
# ─────────────────────────────────────────────
LT_DEBUG=false
LT_UPDATE_MODELS=true
LT_SSL=false
LT_SUGGESTIONS=false
LT_METRICS=false
LT_HOST=0.0.0.0
LT_THREADS=12
LT_FRONTEND_TIMEOUT=2000

# ─────────────────────────────────────────────
# Open Notebook Language Configuration
# ─────────────────────────────────────────────
DEFAULT_LANGUAGE=de
LANGUAGE=de_DE
LANG=de_DE.UTF-8
LC_ALL=de_DE.UTF-8
OPENAI_MODEL=gpt-4o-mini


# ─────────────────────────────────────────────
# SearXNG Configuration
# ─────────────────────────────────────────────
SEARXNG_SECRET=<SEARXNG_SECRET>
SEARXNG_VALKEY_URL=redis://redis:6379/2
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_BIND_ADDRESS=0.0.0.0:8080
SEARXNG_LIMITER=false
SEARXNG_IMAGE_PROXY=true
SEARXNG_LOG_LEVEL=INFO
SEARXNG_CHECK_NETWORK=false
SEARXNG_DISABLE_NETWORK_CHECKS=true

# ─────────────────────────────────────────────
# Crawl4AI LLM Configuration
# ─────────────────────────────────────────────
LLM_PROVIDER=mistral/mistral-large
LLM_TEMPERATURE=0.7
MISTRAL_TEMPERATURE=0.3

# ─────────────────────────────────────────────
# Debugging Configuration
