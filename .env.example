MISTRAL_API_KEY=<MISTRAL_API_KEY>

# PostgreSQL Database
POSTGRES_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=weeWiedoo2zevJKLaejae7Kai2
POSTGRES_DB=n8n
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=${POSTGRES_HOST}
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}
DB_POSTGRESDB_DB=${POSTGRES_DB}

# Version Variables
N8N_VERSION=stable
N8N_RUNNER_VERSION=latest
QDRANT_VERSION=latest
POSTGRES_VERSION=18.3-alpine3.23
NGINX_VERSION=1.29.7-alpine3.23
REDIS_VERSION=8.6.2-alpine3.23

# Namespace prefix for container names
NAMESPACE=jobs

# User/Group IDs for file permissions (run: id -u && id -g)
UID=1000
GID=1000

# Main working directory inside n8n container
MAIN_WORKDIR=/home/node/.n8n

# n8n encryption key (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# Qdrant Vector Database Configuration
# ============================================

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=resumes
QDRANT__LOG_LEVEL=INFO


# Embedding vector dimension (must match your embedding model)
EMBEDDING_DIMENSION=1536

# Number of documents to retrieve in RAG queries
RETRIEVAL_K=5

# Retry configuration for API calls
MAX_RETRIES=4
RETRY_BASE_DELAY=1.0

# ============================================
# Hybrid Search Configuration
# ============================================

HYBRID_ENABLED=true
HYBRID_VECTOR_WEIGHT=0.7
HYBRID_BM25_WEIGHT=0.3
HYBRID_PHRASE_BONUS=0.1

# ============================================
# Additional Configuration from .env
# ============================================

# Qdrant Configuration
QDRANT_URL=http://qdrant:6333

# Core filesystem & data paths (CRITICAL)
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# Security
N8N_ENCRYPTION_KEY=weeWiedoo2zevJKLaejae7Kai2
N8N_USER_MANAGEMENT_JWT_SECRET=weeWiedoo2zevJKLaejae7Kai2

# Networking & runtime
N8N_PORT=5678
N8N_TRUST_PROXY=true
N8N_RUNNERS_MODE=external
N8N_RUNNERS_BROKER_LISTEN_ADDRESS=0.0.0.0
N8N_RUNNERS_AUTH_TOKEN=your_runner_auth_token
N8N_RUNNERS_TASK_BROKER_URI=http://n8n:5679
N8N_RUNNERS_MAX_OLD_SPACE_SIZE=4096

# Features & flags
N8N_FEATURE_FLAGS=aiAgent
N8N_FEATURE_FLAG_CANVAS_V2=false
N8N_TEMPLATES_ENABLED=true
N8N_ALLOW_LOAD_CUSTOM_NODES=true

# UX / UI
N8N_PERSONALIZATION_ENABLED=false
N8N_DISABLE_PRODUCTION_MAIN_MENU=true

# Diagnostics & logging
N8N_DIAGNOSTICS_ENABLED=false
N8N_LOG_LEVEL=warn
N8N_NODES_DEBUG_ENABLED=false

# Git node safety
N8N_GIT_NODE_DISABLE_BARE_REPOS=true

# Permissions (IMPORTANT)
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_REST_API_ENABLED=true

N8N_CUSTOM_EXTENSIONS=/home/node/.n8n
N8N_ENABLE_COMMUNITY_NODES=true

# Webhook & Editor URLs
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678

# Timezone
TZ=Europe/Berlin

# LibreTranslate Configuration
LT_DEBUG=false
LT_UPDATE_MODELS=true
LT_SSL=false
LT_SUGGESTIONS=false
LT_METRICS=false
LT_HOST=0.0.0.0
LT_THREADS=12
LT_FRONTEND_TIMEOUT=2000

# Open Notebook Language Configuration
DEFAULT_LANGUAGE=de
LANGUAGE=de_DE
LANG=de_DE.UTF-8
LC_ALL=de_DE.UTF-8
OPENAI_MODEL=gpt-4o-mini

# Platform & System
PLATFORMS=linux/amd64,linux/arm64
MAIN_WORKDIR=/home/node/.n8n