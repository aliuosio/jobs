# ============================================
# RAG Backend Environment Variables
# Copy to .env and update values as needed
# ============================================

# Qdrant Configuration
# URL for connecting to Qdrant vector database
QDRANT_URL=http://qdrant-db:6333

# Qdrant collection name for resume embeddings
QDRANT_COLLECTION=resumes

# Z.ai API Configuration
# REQUIRED: Your Z.ai API key for embeddings and inference
# Get your key from: https://z.ai/dashboard/api-keys
ZAI_API_KEY=your_api_key_here

# Base URL for Z.ai API endpoints
ZAI_BASE_URL=https://api.z.ai/v1

# Embedding Configuration
# Vector dimension for embeddings (Constitution I compliance)
EMBEDDING_DIMENSION=1536

# Retrieval Configuration
# Number of context chunks to retrieve (Constitution II compliance)
RETRIEVAL_K=5

# Retry Configuration
# Maximum retry attempts for transient failures
MAX_RETRIES=4

# Base delay in seconds for exponential backoff
RETRY_BASE_DELAY=1.0
